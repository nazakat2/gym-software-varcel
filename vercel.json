{
  "version": 2,
  "framework": null,
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @workspace/db push-force && node api-server/build-vercel.mjs && pnpm --filter @workspace/gym-admin run build",
  "outputDirectory": "gym-admin/dist/public",
  "functions": {
    "api/app.mjs": {
      "maxDuration": 30
    }
  },
  "redirects": [
    { "source": "/favicon.ico", "destination": "/favicon.png", "permanent": true }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/app"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
